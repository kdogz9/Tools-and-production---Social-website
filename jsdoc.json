{
    "source": {
        "include": ["."], 
        "includePattern": ".+\\.js$",
        "exclude": ["node_modules", "docs"]
    },
    "opts": {
        "destination": "./docs",
        "recurse": true,
        "readme": "README.md"
    },
    "templates": {
        "cleverLinks": true,
        "monospaceLinks": true
    }
}